# MongoDB connection string for production cluster
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/taskboard

# Port for production (often assigned by host, fallback to 5000)
PORT=5000

# Disable debug logs in production
DEBUG=false

# Frontend origins allowed to call the backend from the browser
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Google OAuth client values from Google Cloud Console
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
# Optional: extra accepted ID-token audiences (comma-separated), e.g. the iOS and
# Android OAuth client IDs used by the mobile apps.
GOOGLE_ALLOWED_AUDIENCES=

# Google Calendar OAuth settings for production
GOOGLE_CALENDAR_REDIRECT_URI=https://your-api-domain.com/api/integrations/google-calendar/callback
APP_URL=https://your-frontend-domain.com

# Generate fresh production secrets locally and keep them out of source control.
GOOGLE_CALENDAR_STATE_SECRET=replace_with_random_state_secret
GOOGLE_CALENDAR_TOKEN_SECRET=replace_with_random_token_secret
