# MongoDB connection string for local development
MONGO_URI=mongodb://localhost:27017/taskboard

# Port your backend server will run on
PORT=5000

# Any other development-only variables
DEBUG=true

# Google OAuth client values from Google Cloud Console
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret

# Google Calendar OAuth settings for local development
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/integrations/google-calendar/callback
APP_URL=http://localhost:3000

# Generate these locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_CALENDAR_STATE_SECRET=replace_with_random_state_secret
GOOGLE_CALENDAR_TOKEN_SECRET=replace_with_random_token_secret
