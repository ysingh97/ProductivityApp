# Base URL of the ProductivityApp backend API (include the /api suffix).
# Android emulator reaches the host machine at 10.0.2.2, not localhost.
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# Google OAuth client IDs (from Google Cloud Console).
# The web client id is used as the token audience the backend verifies.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Developer sign-in against the backend test-auth personas (non-production only,
# requires ALLOW_TEST_AUTH=true on the backend). Do NOT enable in production.
EXPO_PUBLIC_ALLOW_DEV_SIGN_IN=false
EXPO_PUBLIC_DEV_AUTH_TOKEN=test:basic
